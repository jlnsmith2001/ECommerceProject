      <aliases enabled='yes' />
      <column caption='MonthFilter' datatype='string' name='[Calculation_1213318403297280]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF MONTH([TransactionDate]) == 1 THEN &quot;Janurary&quot;&#13;&#10;ELSEIF MONTH([TransactionDate]) == 2 THEN &quot;Feburary&quot;&#13;&#10;ELSEIF MONTH([TransactionDate])== 3 THEN &quot;March&quot;&#13;&#10;ELSEIF MONTH([TransactionDate]) == 4 THEN &quot;April&quot;&#13;&#10;ELSEIF MONTH([TransactionDate]) == 5 THEN &quot;May&quot;&#13;&#10;ELSE &quot;June&quot;&#13;&#10;END' />
      </column>
      <column caption='monthlastdate' datatype='integer' name='[Calculation_1213318409347074]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&quot;month&quot;,[TransactionDate], DATE(&quot;2025-06-30&quot;))' />
      </column>
      <column caption='Last Transaction Date' datatype='datetime' name='[Calculation_1213318435717123]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{FIXED [UserName] : MAX([TransactionDate]) }' />
      </column>
      <column caption='last_purchase' datatype='datetime' name='[Calculation_1213318462672900]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [UserName] : MAX([TransactionDate]) }' />
      </column>
      <column caption='inactive_user' datatype='string' name='[Calculation_1213318462840837]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { Fixed [UserName]: MAX([TransactionDate]) } &lt; #2025-05-01#&#13;&#10;THEN &quot;Inactive&quot;&#13;&#10;ELSE &quot;Active&quot;&#13;&#10;END' />
      </column>
      <column caption='stockcalc' datatype='string' name='[Calculation_2094576955957248]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Stock] &lt; 80 THEN &quot;Low Stock&quot;&#13;&#10;ELSEIF  [Stock] &lt; 160 THEN &quot;Medium Stock&quot;&#13;&#10;ELSE &quot;High Stock&quot;&#13;&#10;END' />
      </column>
